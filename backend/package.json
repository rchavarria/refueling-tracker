{
  "name": "@refueling-tracker/backend",
  "version": "0.0.1",
  "description": "Backend API for refueling-tracker",
  "type": "module",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "7.4.2",
    "@prisma/client": "7.4.2",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "prisma": "7.4.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
